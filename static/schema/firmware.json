{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://meshcore-atlas/schema/firmware.json",
  "title": "Firmware",
  "description": "A MeshCore firmware. The id comes from the directory name, not this file.",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "name",
    "type",
    "maintainer",
    "description",
    "status",
    "devices"
  ],
  "properties": {
    "name": {
      "type": "string",
      "minLength": 1
    },
    "refs": {
      "type": "object",
      "description": "Cross-references to external databases. Each key must be a ref id defined in data/globals.yaml `refs`; each value is this record's id/slug on that site, expanded into a URL via the ref's urlTemplate.",
      "minProperties": 1,
      "additionalProperties": {
        "type": "string",
        "minLength": 1
      }
    },
    "type": {
      "enum": [
        "official",
        "fork",
        "custom"
      ]
    },
    "maintainer": {
      "type": "string",
      "minLength": 1
    },
    "maintainerUrl": {
      "type": "string",
      "pattern": "^https?://",
      "description": "Maintainer's homepage/profile. Defaults to the repository's GitHub owner."
    },
    "maintainers": {
      "type": "array",
      "description": "Individual maintainers/contributors, each optionally linked. Shown on the detail page in place of the single `maintainer` string.",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "name"
        ],
        "properties": {
          "name": {
            "type": "string",
            "minLength": 1
          },
          "url": {
            "type": "string",
            "pattern": "^https?://"
          }
        }
      }
    },
    "description": {
      "type": "string",
      "minLength": 1
    },
    "status": {
      "enum": [
        "active",
        "maintenance",
        "inactive",
        "experimental"
      ]
    },
    "lifecycle": {
      "enum": [
        "active",
        "maintenance",
        "archived"
      ]
    },
    "maturity": {
      "enum": [
        "experimental",
        "alpha",
        "beta",
        "stable"
      ]
    },
    "distribution": {
      "enum": [
        "official",
        "vendor",
        "community",
        "personal"
      ]
    },
    "lineage": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "kind": {
          "enum": [
            "upstream",
            "fork",
            "reimplementation"
          ]
        },
        "upstreamFirmwareId": {
          "type": "string",
          "pattern": "^[a-z0-9-]+$"
        },
        "upstreamRepository": {
          "type": "string"
        }
      }
    },
    "runtime": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "framework": {
          "enum": [
            "arduino",
            "zephyr",
            "esp-idf",
            "other"
          ]
        },
        "language": {
          "type": "string"
        }
      }
    },
    "repository": {
      "type": "string"
    },
    "website": {
      "type": "string"
    },
    "license": {
      "type": "string"
    },
    "latest_version": {
      "type": "string",
      "description": "Computed at build time from changelog.yaml when present. Set manually in firmware.yaml only when there is no changelog."
    },
    "released": {
      "type": "string",
      "description": "YYYY-MM-DD of latest_version. Computed at build time from changelog.yaml when present. Set manually in firmware.yaml only when there is no changelog."
    },
    "roles": {
      "type": "array",
      "items": {
        "enum": [
          "companion",
          "repeater",
          "room-server",
          "observer",
          "sensor",
          "kiss-modem",
          "standalone-ui"
        ]
      }
    },
    "features": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "capabilities": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "protocol": {
          "type": "object",
          "additionalProperties": false,
          "properties": {
            "meshcoreCompatible": {
              "type": "boolean"
            },
            "rawPacketSend": {
              "type": "boolean"
            },
            "rawPacketObserve": {
              "type": "boolean"
            }
          }
        },
        "transports": {
          "type": "object",
          "additionalProperties": false,
          "properties": {
            "ble": {
              "type": "boolean"
            },
            "usbSerial": {
              "type": "boolean"
            },
            "nativeTcp": {
              "type": "boolean"
            },
            "wifiAp": {
              "type": "boolean"
            },
            "ethernet": {
              "type": "boolean"
            }
          }
        },
        "operations": {
          "type": "object",
          "additionalProperties": false,
          "properties": {
            "webFlasher": {
              "type": "boolean"
            },
            "ota": {
              "type": "boolean"
            },
            "bleDfu": {
              "type": "boolean"
            },
            "configurationBackup": {
              "type": "boolean"
            }
          }
        },
        "networking": {
          "type": "object",
          "additionalProperties": false,
          "properties": {
            "repeater": {
              "type": "boolean"
            },
            "roomServer": {
              "type": "boolean"
            },
            "observer": {
              "type": "boolean"
            },
            "mqtt": {
              "type": "boolean"
            },
            "kissModem": {
              "type": "boolean"
            }
          }
        },
        "hardware": {
          "type": "object",
          "additionalProperties": false,
          "properties": {
            "gps": {
              "type": "boolean"
            },
            "display": {
              "type": "boolean"
            },
            "sensors": {
              "type": "boolean"
            },
            "lowPowerRx": {
              "type": "boolean"
            }
          }
        }
      }
    },
    "changelog": {
      "type": "object",
      "additionalProperties": false,
      "description": "Release source config. Defaults to GitHub releases parsed from `repository`.",
      "properties": {
        "source": {
          "enum": [
            "github",
            "manual",
            "script"
          ]
        },
        "repo": {
          "type": "string",
          "description": "owner/name override"
        },
        "script": {
          "type": "string",
          "description": "filename in the firmware dir, for source: script"
        }
      }
    },
    "devices": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "id",
          "status"
        ],
        "properties": {
          "id": {
            "type": "string",
            "pattern": "^[a-z0-9-]+$"
          },
          "status": {
            "enum": [
              "supported",
              "partial",
              "untested",
              "unsupported"
            ]
          },
          "target": {
            "type": "string",
            "pattern": "^[A-Za-z0-9_.-]+$"
          },
          "platformio_board": {
            "type": "string",
            "pattern": "^[A-Za-z0-9_.-]+$"
          },
          "notes": {
            "type": "string"
          }
        }
      }
    }
  }
}
