{
  "name": "meshcore-ninja",
  "version": "2026.6.0",
  "description": "A database and compatibility matrix of MeshCore firmwares, built from human-readable YAML files.",
  "type": "module",
  "scripts": {
    "build:data": "node scripts/build-data.js",
    "build:og": "node scripts/build-og.js",
    "build:schema": "node scripts/build-schemas.js",
    "brand": "bash scripts/generate-brand-assets.sh",
    "changelogs": "node scripts/update-changelogs.js",
    "check:presets": "node scripts/check-app-presets.js",
    "import:presets": "node scripts/check-app-presets.js --import",
    "enrich:firmwares": "node scripts/enrich-firmwares.js",
    "enrich:contributors": "node scripts/enrich-contributors.js",
    "enrich:avatars": "node scripts/download-avatars.js",
    "predev": "node scripts/build-data.js",
    "dev": "vite dev",
    "prebuild": "node scripts/build-data.js && node scripts/build-og.js",
    "build": "vite build",
    "postbuild": "node scripts/build-schemas.js",
    "preview": "vite preview",
    "validate": "node scripts/validate.js",
    "test": "node scripts/check-locales.js && node scripts/validate.js && node scripts/catalog-i18n/test.js",
    "i18n:translate": "node scripts/catalog-i18n/translate.js",
    "i18n:translate:test": "node scripts/catalog-i18n/translate-test.js",
    "i18n:status": "node scripts/catalog-i18n/status.js"
  },
  "devDependencies": {
    "@fontsource/inter": "^5.2.8",
    "@iconify-json/lucide": "^1.2.114",
    "@iconify-json/simple-icons": "^1.2.87",
    "@iconify/utils": "^3.1.3",
    "@inlang/paraglide-js": "^2.20.2",
    "@resvg/resvg-js": "^2.6.2",
    "@sveltejs/adapter-static": "^3.0.10",
    "@sveltejs/kit": "^2.66.0",
    "@sveltejs/vite-plugin-svelte": "^7.1.2",
    "@tailwindcss/vite": "^4.3.1",
    "@vite-pwa/sveltekit": "^1.1.0",
    "ajv": "^8.20.0",
    "js-yaml": "^5.0.0",
    "lucide-static": "^1.21.0",
    "marked": "^18.0.5",
    "sanitize-html": "^2.17.5",
    "satori": "^0.26.0",
    "svelte": "^5.56.3",
    "tailwindcss": "^4.3.1",
    "turndown": "^7.2.4",
    "vite": "^8.0.16"
  },
  "dependencies": {
    "@iconify/svelte": "^5.2.2",
    "@lucide/svelte": "^1.21.0",
    "bits-ui": "^2.18.1",
    "country-flag-icons": "^1.6.18",
    "devicon": "^2.17.0",
    "fuse.js": "^7.4.2",
    "leaflet": "^1.9.4"
  }
}
